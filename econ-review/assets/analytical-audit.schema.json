{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/analytical-audit.schema.json",
  "title": "econ-review analytical ledgers",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "scope", "domains"],
  "properties": {
    "schema_version": {"enum": ["0.1", "0.2"]},
    "review_id": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inventory_complete_within_assessment_boundary", "coverage_unit_ids", "boundary_notes"],
      "properties": {
        "inventory_complete_within_assessment_boundary": {"const": true},
        "coverage_unit_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "boundary_notes": {"type": "string", "minLength": 1}
      }
    },
    "domains": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "status", "coverage_unit_ids", "entries", "notes"],
        "properties": {
          "kind": {
            "enum": [
              "partition-regime",
              "measure-algebra",
              "assumption-implementation",
              "derived-number",
              "comparison-harmonization",
              "timing-test",
              "availability-exclusivity"
            ]
          },
          "status": {"enum": ["complete", "bounded", "not_applicable"]},
          "coverage_unit_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "object", "status", "coverage_unit_ids", "evidence_locators", "evidence", "checks", "finding_ids", "notes"],
              "properties": {
                "id": {"type": "string", "pattern": "^ANA-[A-Z]+-[0-9]{2,}$"},
                "object": {"type": "string", "minLength": 1},
                "status": {"enum": ["clear", "issue", "bounded"]},
                "coverage_unit_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
                "evidence_refs": {"$ref": "#/$defs/evidenceRefs"},
                "evidence_locators": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["source", "locator", "content"],
                    "properties": {
                      "source": {"type": "string", "minLength": 1},
                      "locator": {"type": "string", "minLength": 1},
                      "content": {"type": "string", "minLength": 1},
                      "coverage_unit_id": {"type": "string", "minLength": 1},
                      "anchor_id": {"type": ["string", "null"], "pattern": "^ANC-[0-9]{2,}$"},
                      "representation": {"enum": ["verbatim", "normalized_transcription", "reviewer_observation", "checked_absence", "computed_result", "external_source"]},
                      "record_ref": {"$ref": "#/$defs/evidenceRef"}
                    }
                  }
                },
                "evidence": {"type": "string", "minLength": 1},
                "checks": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["id", "name", "status", "result"],
                    "properties": {
                      "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
                      "name": {"type": "string", "minLength": 1},
                      "status": {"enum": ["clear", "issue", "bounded", "not_applicable"]},
                      "result": {"type": "string", "minLength": 1}
                    }
                  }
                },
                "finding_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
                "notes": {"type": "string", "minLength": 1}
              }
            }
          },
          "notes": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"status": {"const": "complete"}}},
            "then": {
              "properties": {
                "coverage_unit_ids": {"minItems": 1},
                "entries": {"minItems": 1}
              }
            }
          },
          {
            "if": {"properties": {"status": {"const": "not_applicable"}}},
            "then": {
              "properties": {
                "coverage_unit_ids": {"maxItems": 0},
                "entries": {"maxItems": 0}
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"enum": ["anchor", "finding_evidence", "computation", "external_source"]},
        "id": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "anchor"}}, "required": ["kind"]}, "then": {"properties": {"id": {"pattern": "^ANC-[0-9]{2,}$"}}}},
        {"if": {"properties": {"kind": {"const": "finding_evidence"}}, "required": ["kind"]}, "then": {"properties": {"id": {"pattern": "^EVD-[A-Z0-9_-]+$"}}}},
        {"if": {"properties": {"kind": {"const": "computation"}}, "required": ["kind"]}, "then": {"properties": {"id": {"pattern": "^CMP-[0-9]{2,}$"}}}},
        {"if": {"properties": {"kind": {"const": "external_source"}}, "required": ["kind"]}, "then": {"properties": {"id": {"pattern": "^EXT-[0-9]{2,}$"}}}}
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/evidenceRef"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "0.2"}}, "required": ["schema_version"]},
      "then": {
        "properties": {
          "domains": {
            "items": {
              "properties": {
                "entries": {
                  "items": {
                    "required": ["evidence_refs"],
                    "properties": {
                      "evidence_locators": {
                        "items": {
                          "required": ["coverage_unit_id", "anchor_id", "representation", "record_ref"],
                          "allOf": [
                            {
                              "if": {"properties": {"representation": {"enum": ["verbatim", "normalized_transcription", "reviewer_observation"]}}, "required": ["representation"]},
                              "then": {"properties": {"record_ref": {"properties": {"kind": {"enum": ["anchor", "finding_evidence"]}}}}}
                            },
                            {
                              "if": {"properties": {"representation": {"const": "checked_absence"}}, "required": ["representation"]},
                              "then": {"properties": {"record_ref": {"properties": {"kind": {"enum": ["anchor", "finding_evidence"]}}}}}
                            },
                            {
                              "if": {"properties": {"representation": {"const": "computed_result"}}, "required": ["representation"]},
                              "then": {"properties": {"record_ref": {"properties": {"kind": {"const": "computation"}}}}}
                            },
                            {
                              "if": {"properties": {"representation": {"const": "external_source"}}, "required": ["representation"]},
                              "then": {"properties": {"record_ref": {"properties": {"kind": {"const": "external_source"}}}}}
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
