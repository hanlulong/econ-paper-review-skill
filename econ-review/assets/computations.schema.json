{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/computations.schema.json",
  "title": "econ-review reproducible computations",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "computations"],
  "properties": {
    "schema_version": {"enum": ["0.1", "0.2"]},
    "review_id": {"type": "string", "minLength": 1},
    "computations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "finding_ids", "input_anchor_ids", "tool", "method", "result", "artifact_path", "artifact_sha256", "tolerance"],
        "properties": {
          "id": {"type": "string", "pattern": "^CMP-[0-9]{2,}$"},
          "finding_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "audit_links": {
            "type": "array",
            "uniqueItems": true,
            "items": {"$ref": "#/$defs/auditLink"}
          },
          "input_anchor_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^ANC-[0-9]{2,}$"}},
          "tool": {"type": "string", "minLength": 1},
          "method": {"type": "string", "minLength": 1},
          "result": {"type": "string", "minLength": 1},
          "artifact_path": {"type": "string", "minLength": 1},
          "artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "tolerance": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "auditLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"enum": ["analytical_entry", "magnitude_assessment"]},
        "id": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "analytical_entry"}}, "required": ["kind"]}, "then": {"properties": {"id": {"pattern": "^ANA-[A-Z]+-[0-9]{2,}$"}}}},
        {"if": {"properties": {"kind": {"const": "magnitude_assessment"}}, "required": ["kind"]}, "then": {"properties": {"id": {"pattern": "^MAG-[0-9]{2,}$"}}}}
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "0.1"}}, "required": ["schema_version"]},
      "then": {
        "properties": {
          "computations": {
            "items": {
              "properties": {
                "finding_ids": {"minItems": 1},
                "audit_links": {"maxItems": 0}
              }
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "0.2"}}, "required": ["schema_version"]},
      "then": {
        "properties": {
          "computations": {
            "items": {
              "required": ["audit_links"],
              "anyOf": [
                {"properties": {"finding_ids": {"minItems": 1}}},
                {"properties": {"audit_links": {"minItems": 1}}}
              ]
            }
          }
        }
      }
    }
  ]
}
