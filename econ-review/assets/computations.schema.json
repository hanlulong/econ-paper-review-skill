{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/computations.schema.json",
  "title": "econ-review reproducible computations",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "computations"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "review_id": {"type": "string", "minLength": 1},
    "computations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "finding_ids", "input_anchor_ids", "tool", "method", "result", "artifact_path", "artifact_sha256", "tolerance"],
        "properties": {
          "id": {"type": "string", "pattern": "^CMP-[0-9]{2,}$"},
          "finding_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "input_anchor_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^ANC-[0-9]{2,}$"}},
          "tool": {"type": "string", "minLength": 1},
          "method": {"type": "string", "minLength": 1},
          "result": {"type": "string", "minLength": 1},
          "artifact_path": {"type": "string", "minLength": 1},
          "artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "tolerance": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
