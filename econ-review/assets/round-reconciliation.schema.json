{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/round-reconciliation.schema.json",
  "title": "econ-review reviewer-owned round reconciliation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "review_id", "prior_review_id", "prior_findings_sha256",
    "review_actions_sha256", "revision_tasks_sha256", "agent_response_sha256",
    "plan_id", "records", "successor_consolidations", "new_finding_ids"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "review_id": {"$ref": "#/$defs/trimmed_text"},
    "prior_review_id": {"$ref": "#/$defs/trimmed_text"},
    "prior_findings_sha256": {"$ref": "#/$defs/sha256"},
    "review_actions_sha256": {"$ref": "#/$defs/sha256"},
    "revision_tasks_sha256": {"$ref": "#/$defs/sha256"},
    "agent_response_sha256": {
      "oneOf": [
        {"$ref": "#/$defs/sha256"},
        {"type": "null"}
      ]
    },
    "plan_id": {"type": "string", "format": "uuid"},
    "records": {
      "type": "array",
      "maxItems": 20000,
      "items": {"$ref": "#/$defs/record"}
    },
    "successor_consolidations": {
      "type": "array",
      "maxItems": 20000,
      "description": "Explicit declarations for a current finding that consolidates two or more superseded prior findings.",
      "items": {"$ref": "#/$defs/successor_consolidation"}
    },
    "new_finding_ids": {
      "type": "array",
      "maxItems": 20000,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/finding_id"}
    }
  },
  "$defs": {
    "trimmed_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000,
      "pattern": "^\\S(?:[\\s\\S]*\\S)?$"
    },
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "finding_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]{2,}$"},
    "anchor_id": {"type": "string", "pattern": "^ANC-[0-9]{2,}$"},
    "computation_id": {"type": "string", "pattern": "^CMP-[0-9]{2,}$"},
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "result", "anchor_ids", "computation_ids", "notes"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Open, method-neutral reviewer check label such as claim_scope, derivation, exhibit_consistency, or robustness."
        },
        "result": {"enum": ["passed", "failed", "bounded"]},
        "anchor_ids": {
          "type": "array",
          "maxItems": 2000,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/anchor_id"}
        },
        "computation_ids": {
          "type": "array",
          "maxItems": 2000,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/computation_id"}
        },
        "notes": {"$ref": "#/$defs/trimmed_text"}
      },
      "anyOf": [
        {"properties": {"anchor_ids": {"minItems": 1}}},
        {"properties": {"computation_ids": {"minItems": 1}}}
      ]
    },
    "successor_consolidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["successor_finding_id", "prior_finding_ids", "rationale"],
      "properties": {
        "successor_finding_id": {"$ref": "#/$defs/finding_id"},
        "prior_finding_ids": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20000,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/finding_id"}
        },
        "rationale": {
          "$ref": "#/$defs/trimmed_text",
          "description": "Why one current diagnosis now represents all listed prior concerns."
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_finding_id", "adjudicated_by", "outcome", "successor_finding_ids",
        "rationale", "checks"
      ],
      "properties": {
        "prior_finding_id": {"$ref": "#/$defs/finding_id"},
        "adjudicated_by": {"const": "reviewer"},
        "outcome": {
          "enum": [
            "resolved", "partly_resolved", "unchanged", "superseded", "user_excluded"
          ]
        },
        "successor_finding_ids": {
          "type": "array",
          "maxItems": 20000,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/finding_id"}
        },
        "rationale": {"$ref": "#/$defs/trimmed_text"},
        "checks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2000,
          "items": {"$ref": "#/$defs/check"}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"outcome": {"enum": ["resolved", "user_excluded"]}},
            "required": ["outcome"]
          },
          "then": {"properties": {"successor_finding_ids": {"maxItems": 0}}}
        },
        {
          "if": {
            "properties": {
              "outcome": {"enum": ["partly_resolved", "unchanged"]}
            },
            "required": ["outcome"]
          },
          "then": {"properties": {"successor_finding_ids": {"minItems": 1, "maxItems": 1}}}
        },
        {
          "if": {"properties": {"outcome": {"const": "superseded"}}, "required": ["outcome"]},
          "then": {"properties": {"successor_finding_ids": {"minItems": 1}}}
        }
      ]
    }
  }
}
