{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/verification.schema.json",
  "title": "econ-review source-grounded verification ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "records"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "review_id": {"type": "string", "minLength": 1},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "status", "checks"],
        "properties": {
          "finding_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]{2,}$"},
          "status": {"enum": ["passed", "bounded", "failed"]},
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["evidence_id", "check_type", "result", "notes"],
              "properties": {
                "evidence_id": {"type": "string", "pattern": "^EVD-[A-Z0-9_-]+$"},
                "check_type": {"enum": ["exact_source_span", "source_hash", "computation", "external_source", "checked_absence"]},
                "result": {"enum": ["passed", "bounded", "failed"]},
                "anchor_id": {"type": ["string", "null"], "pattern": "^ANC-[0-9]{2,}$"},
                "computation_id": {"type": ["string", "null"], "pattern": "^CMP-[0-9]{2,}$"},
                "source_record_id": {"type": ["string", "null"], "pattern": "^EXT-[0-9]{2,}$"},
                "notes": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
