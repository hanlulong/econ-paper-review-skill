{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/figures.schema.json",
  "title": "econ-review separate figure audit",
  "type": "object",
  "$defs": {
    "safe_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*[\\\\:])(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\x00-\\x1f\\x7f]).+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axes_scales_units",
        "legend_series_panels",
        "uncertainty",
        "legibility_accessibility",
        "visual_integrity"
      ],
      "properties": {
        "axes_scales_units": {"type": "string", "minLength": 1},
        "legend_series_panels": {"type": "string", "minLength": 1},
        "uncertainty": {"type": "string", "minLength": 1},
        "legibility_accessibility": {"type": "string", "minLength": 1},
        "visual_integrity": {"type": "string", "minLength": 1}
      }
    },
    "visible_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "text", "status", "notes"],
      "properties": {
        "basis": {
          "enum": [
            "figure_label",
            "caption_or_title",
            "panel_or_axis_text",
            "legend_or_annotation",
            "distinctive_visible_text",
            "visual_structure"
          ]
        },
        "text": {"type": "string", "minLength": 1},
        "status": {"enum": ["matched", "mismatch", "bounded"]},
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "assessment_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked_scope",
        "status_basis",
        "reason",
        "missing_input",
        "decisive_evidence_needed"
      ],
      "properties": {
        "checked_scope": {"type": "string", "minLength": 1},
        "status_basis": {
          "enum": [
            "unreadable_render",
            "ambiguous_visual_identity",
            "incomplete_extraction",
            "missing_surrounding_context",
            "unavailable_source",
            "other"
          ]
        },
        "reason": {"type": "string", "minLength": 1},
        "missing_input": {"type": "string", "minLength": 1},
        "decisive_evidence_needed": {"type": "string", "minLength": 1}
      }
    },
    "source_locator_v0_2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "pages"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^SRC-[0-9]{2,}$"},
        "pages": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        },
        "context": {"type": "string", "minLength": 1}
      }
    },
    "rendered_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "pdf_page",
        "render_type",
        "source_object_id",
        "visible_identity"
      ],
      "properties": {
        "path": {"$ref": "#/$defs/safe_path"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "pdf_page": {"type": ["integer", "null"], "minimum": 1},
        "render_type": {"enum": ["crop", "full_page"]},
        "source_object_id": {
          "type": ["string", "null"],
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "visible_identity": {"$ref": "#/$defs/visible_identity"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"render_type": {"const": "full_page"}},
            "required": ["render_type"]
          },
          "then": {"properties": {"source_object_id": {"type": "null"}}}
        }
      ]
    },
    "figure_v0_1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "pdf_pages",
        "source_locator",
        "extraction_paths",
        "kind",
        "visual_status",
        "caption_text_status",
        "claim_correspondence_status",
        "checks",
        "finding_ids",
        "notes"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^FIG-[0-9]{2,}$"},
        "label": {"type": "string", "minLength": 1},
        "pdf_pages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        },
        "source_locator": {"type": "string", "minLength": 1},
        "extraction_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "kind": {
          "enum": ["chart", "plot", "diagram", "map", "image", "multi_panel", "other"]
        },
        "visual_status": {"enum": ["clear", "issue", "bounded"]},
        "caption_text_status": {"enum": ["consistent", "issue", "bounded"]},
        "claim_correspondence_status": {"enum": ["consistent", "issue", "bounded"]},
        "checks": {"$ref": "#/$defs/checks"},
        "finding_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "figure_v0_2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_id",
        "coverage_unit_id",
        "label",
        "pdf_pages",
        "source_locator",
        "identity_keys",
        "rendered_assets",
        "kind",
        "visual_status",
        "caption_text_status",
        "claim_correspondence_status",
        "checks",
        "assessment_boundary",
        "finding_ids",
        "notes"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^FIG-[0-9]{2,}$"},
        "source_id": {"type": "string", "pattern": "^SRC-[0-9]{2,}$"},
        "coverage_unit_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "pdf_pages": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        },
        "source_locator": {"$ref": "#/$defs/source_locator_v0_2"},
        "identity_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 2}
        },
        "rendered_assets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/rendered_asset"},
          "contains": {
            "type": "object",
            "required": ["render_type"],
            "properties": {"render_type": {"const": "full_page"}}
          },
          "minContains": 1
        },
        "kind": {
          "enum": ["chart", "plot", "diagram", "map", "image", "multi_panel", "other"]
        },
        "visual_status": {"enum": ["clear", "issue", "bounded"]},
        "caption_text_status": {"enum": ["consistent", "issue", "bounded"]},
        "claim_correspondence_status": {"enum": ["consistent", "issue", "bounded"]},
        "checks": {"$ref": "#/$defs/checks"},
        "assessment_boundary": {
          "oneOf": [
            {"$ref": "#/$defs/assessment_boundary"},
            {"type": "null"}
          ]
        },
        "finding_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "notes": {"type": "string", "minLength": 1}
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "source_render",
    "inventory_complete_within_assessment_boundary",
    "no_figures_confirmed",
    "figures",
    "boundary_notes"
  ],
  "properties": {
    "schema_version": {"enum": ["0.1", "0.2"]},
    "review_id": {"type": "string", "minLength": 1},
    "source_render": {"type": "string", "minLength": 1},
    "inventory_complete_within_assessment_boundary": {"const": true},
    "no_figures_confirmed": {"type": "boolean"},
    "boundary_notes": {"type": "string", "minLength": 1},
    "figures": {"type": "array"}
  },
  "allOf": [
    {
      "if": {"properties": {"no_figures_confirmed": {"const": true}}},
      "then": {"properties": {"figures": {"maxItems": 0}}},
      "else": {"properties": {"figures": {"minItems": 1}}}
    }
  ],
  "oneOf": [
    {
      "properties": {
        "schema_version": {"const": "0.1"},
        "figures": {"items": {"$ref": "#/$defs/figure_v0_1"}}
      }
    },
    {
      "properties": {
        "schema_version": {"const": "0.2"},
        "figures": {"items": {"$ref": "#/$defs/figure_v0_2"}}
      }
    }
  ]
}
