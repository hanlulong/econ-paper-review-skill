{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/figures.schema.json",
  "title": "econ-review separate figure audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "source_render", "inventory_complete_within_assessment_boundary", "no_figures_confirmed", "figures", "boundary_notes"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "review_id": {"type": "string", "minLength": 1},
    "source_render": {"type": "string", "minLength": 1},
    "inventory_complete_within_assessment_boundary": {"const": true},
    "no_figures_confirmed": {"type": "boolean"},
    "boundary_notes": {"type": "string", "minLength": 1},
    "figures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "pdf_pages", "source_locator", "extraction_paths", "kind", "visual_status", "caption_text_status", "claim_correspondence_status", "checks", "finding_ids", "notes"],
        "properties": {
          "id": {"type": "string", "pattern": "^FIG-[0-9]{2,}$"},
          "label": {"type": "string", "minLength": 1},
          "pdf_pages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
          "source_locator": {"type": "string", "minLength": 1},
          "extraction_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "kind": {"enum": ["chart", "plot", "diagram", "map", "image", "multi_panel", "other"]},
          "visual_status": {"enum": ["clear", "issue", "bounded"]},
          "caption_text_status": {"enum": ["consistent", "issue", "bounded"]},
          "claim_correspondence_status": {"enum": ["consistent", "issue", "bounded"]},
          "checks": {
            "type": "object", "additionalProperties": false,
            "required": ["axes_scales_units", "legend_series_panels", "uncertainty", "legibility_accessibility", "visual_integrity"],
            "properties": {
              "axes_scales_units": {"type": "string", "minLength": 1},
              "legend_series_panels": {"type": "string", "minLength": 1},
              "uncertainty": {"type": "string", "minLength": 1},
              "legibility_accessibility": {"type": "string", "minLength": 1},
              "visual_integrity": {"type": "string", "minLength": 1}
            }
          },
          "finding_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "notes": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"no_figures_confirmed": {"const": true}}},
      "then": {"properties": {"figures": {"maxItems": 0}}},
      "else": {"properties": {"figures": {"minItems": 1}}}
    }
  ]
}
