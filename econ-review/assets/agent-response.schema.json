{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/agent-response.schema.json",
  "title": "econ-review implementation-agent response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "kind", "plan_id", "source_review_id",
    "source_review_fingerprint", "responded_at", "entries"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "kind": {"const": "econ-review-agent-response"},
    "plan_id": {"type": "string", "format": "uuid"},
    "source_review_id": {"$ref": "#/$defs/trimmed_text"},
    "source_review_fingerprint": {
      "$ref": "#/$defs/trimmed_text",
      "description": "Unchanged findings.json byte fingerprint copied from the bound revision plan."
    },
    "responded_at": {"type": ["string", "null"], "format": "date-time"},
    "entries": {
      "type": "array",
      "maxItems": 200,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "trimmed_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000,
      "pattern": "^\\S(?:[\\s\\S]*\\S)?$"
    },
    "portable_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))\\S(?:[^\\r\\n]*\\S)?$"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "locator", "summary"],
      "properties": {
        "path": {"$ref": "#/$defs/portable_path"},
        "locator": {"$ref": "#/$defs/trimmed_text"},
        "summary": {"$ref": "#/$defs/trimmed_text"}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "result", "details"],
      "properties": {
        "check": {"$ref": "#/$defs/trimmed_text"},
        "result": {"enum": ["passed", "failed", "not_run"]},
        "details": {"type": "string", "maxLength": 20000}
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id", "status", "response", "changed_files",
        "changed_locations", "verification", "blocker"
      ],
      "properties": {
        "finding_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]{2,}$"},
        "status": {"enum": ["changed", "response_only", "partial", "blocked", "not_attempted"]},
        "response": {"type": "string", "maxLength": 20000},
        "changed_files": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/portable_path"}
        },
        "changed_locations": {
          "type": "array",
          "maxItems": 2000,
          "items": {"$ref": "#/$defs/location"}
        },
        "verification": {
          "type": "array",
          "maxItems": 1000,
          "items": {"$ref": "#/$defs/verification"}
        },
        "blocker": {"type": ["string", "null"], "maxLength": 20000}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "changed"}}, "required": ["status"]},
          "then": {
            "properties": {
              "response": {"type": "string", "pattern": "\\S"},
              "changed_files": {"minItems": 1},
              "changed_locations": {"minItems": 1},
              "verification": {"minItems": 1},
              "blocker": {"const": null}
            }
          }
        },
        {
          "if": {"properties": {"status": {"const": "response_only"}}, "required": ["status"]},
          "then": {
            "properties": {
              "response": {"type": "string", "pattern": "\\S"},
              "changed_files": {"maxItems": 0},
              "changed_locations": {"maxItems": 0},
              "blocker": {"const": null}
            }
          }
        },
        {
          "if": {"properties": {"status": {"const": "partial"}}, "required": ["status"]},
          "then": {
            "properties": {
              "response": {"type": "string", "pattern": "\\S"}
            }
          }
        },
        {
          "if": {"properties": {"status": {"const": "blocked"}}, "required": ["status"]},
          "then": {
            "properties": {
              "response": {"type": "string", "pattern": "\\S"},
              "changed_files": {"maxItems": 0},
              "changed_locations": {"maxItems": 0},
              "blocker": {"type": "string", "pattern": "\\S"}
            }
          }
        },
        {
          "if": {"properties": {"status": {"const": "not_attempted"}}, "required": ["status"]},
          "then": {
            "properties": {
              "response": {"maxLength": 0},
              "changed_files": {"maxItems": 0},
              "changed_locations": {"maxItems": 0},
              "verification": {"maxItems": 0},
              "blocker": {"const": null}
            }
          }
        }
      ]
    }
  }
}
