{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/candidates.schema.json",
  "title": "econ-review candidate discovery and disposition ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "passes", "candidates"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "review_id": {"type": "string", "minLength": 1},
    "passes": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/pass"}
    },
    "candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate"}
    }
  },
  "$defs": {
    "pass": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "kind", "role", "scope", "coverage_unit_ids", "burden_ids",
        "status", "boundary"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^PASS-[0-9]{2,}$"},
        "kind": {
          "enum": [
            "source_order", "cross_unit", "object_specific", "literature",
            "writing_reader", "replication", "low_count_recovery",
            "saturation", "other"
          ]
        },
        "role": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "coverage_unit_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "burden_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "status": {"enum": ["completed", "bounded"]},
        "boundary": {"type": ["string", "null"], "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "completed"}}, "required": ["status"]},
          "then": {"properties": {"boundary": {"type": "null"}}}
        },
        {
          "if": {"properties": {"status": {"const": "bounded"}}, "required": ["status"]},
          "then": {"properties": {"boundary": {"type": "string", "minLength": 1}}}
        }
      ]
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "pass_id", "coverage_unit_ids", "burden_ids", "locator",
        "provisional_issue", "consequence", "proposed_repair",
        "strongest_author_reply", "disposition", "disposition_reason",
        "finding_id", "merged_into_candidate_id"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^CND-[0-9]{3,}$"},
        "pass_id": {"type": "string", "pattern": "^PASS-[0-9]{2,}$"},
        "coverage_unit_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "burden_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "locator": {"type": "string", "minLength": 1},
        "provisional_issue": {"type": "string", "minLength": 1},
        "consequence": {"type": "string", "minLength": 1},
        "proposed_repair": {"type": ["string", "null"], "minLength": 1},
        "strongest_author_reply": {"type": ["string", "null"], "minLength": 1},
        "disposition": {"enum": ["admitted", "weakened", "refuted", "merged", "bounded"]},
        "disposition_reason": {"type": "string", "minLength": 1},
        "finding_id": {
          "type": ["string", "null"],
          "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]{2,}$"
        },
        "merged_into_candidate_id": {
          "type": ["string", "null"],
          "pattern": "^CND-[0-9]{3,}$"
        }
      },
      "allOf": [
        {
          "if": {"properties": {"disposition": {"const": "admitted"}}, "required": ["disposition"]},
          "then": {
            "properties": {
              "finding_id": {"type": "string"},
              "merged_into_candidate_id": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"disposition": {"const": "weakened"}}, "required": ["disposition"]},
          "then": {
            "properties": {
              "finding_id": {"type": "string"},
              "merged_into_candidate_id": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"disposition": {"const": "merged"}}, "required": ["disposition"]},
          "then": {
            "properties": {
              "finding_id": {"type": "string"},
              "merged_into_candidate_id": {"type": "string"}
            }
          }
        },
        {
          "if": {
            "properties": {"disposition": {"enum": ["refuted", "bounded"]}},
            "required": ["disposition"]
          },
          "then": {
            "properties": {
              "finding_id": {"type": "null"},
              "merged_into_candidate_id": {"type": "null"}
            }
          }
        }
      ]
    }
  }
}
