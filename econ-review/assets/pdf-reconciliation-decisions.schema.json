{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/pdf-reconciliation-decisions.schema.json",
  "title": "Render-backed PDF reconciliation decisions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "source_sha256", "packets_sha256", "protocol_version",
    "created_at", "scope_status", "decisions", "summary"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "source_sha256": {"$ref": "#/$defs/sha256"},
    "packets_sha256": {"$ref": "#/$defs/sha256"},
    "protocol_version": {"const": "render-adjudication-v1"},
    "created_at": {"type": "string", "format": "date-time"},
    "scope_status": {"enum": ["partial", "bounded", "verified_scope"]},
    "decisions": {"type": "array", "items": {"$ref": "#/$defs/decision"}},
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["model_adjudicated", "render_verified", "bounded"],
      "properties": {
        "model_adjudicated": {"type": "integer", "minimum": 0},
        "render_verified": {"type": "integer", "minimum": 0},
        "bounded": {"type": "integer", "minimum": 0}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decision": {
      "type": "object", "additionalProperties": false,
      "required": [
        "target_id", "page", "state", "evidence_hashes", "transcription",
        "alternatives", "unreadable_regions", "verifier", "verification_note"
      ],
      "properties": {
        "target_id": {"type": "string", "pattern": "^SRC-[0-9]{2,}-PDF-(B[0-9]{4,}|(TBL|FIG|EQ)-[0-9]{3,})$"},
        "page": {"type": "integer", "minimum": 1},
        "state": {"enum": ["model_adjudicated", "render_verified", "bounded"]},
        "evidence_hashes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
        "transcription": {"type": ["string", "null"]},
        "alternatives": {"type": "array", "items": {"type": "string"}},
        "unreadable_regions": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "verifier": {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "name", "version"],
          "properties": {
            "kind": {"enum": ["human", "model"]},
            "name": {"type": "string", "minLength": 1},
            "version": {"type": ["string", "null"]}
          }
        },
        "verification_note": {"type": "string", "minLength": 1}
      }
    }
  }
}
