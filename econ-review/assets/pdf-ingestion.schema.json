{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/pdf-ingestion.schema.json",
  "title": "econ-review verified PDF transcription and proposal package",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"enum": ["0.2", "0.3"]}}},
      "then": {
        "required": ["proposals", "reconciliation"],
        "properties": {
          "toolchain": {"required": ["semantic_backends"]},
          "configuration": {
            "required": [
              "semantic_backend", "allow_model_downloads", "docling_formulas",
              "docling_timeout", "docling_device", "mathpix", "mathpix_timeout",
              "mathpix_poll_interval", "external_upload_authorization",
              "mathpix_retention_accepted"
            ]
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "0.3"}}},
      "then": {"required": ["detector_contract"]}
    }
  ],
  "required": [
    "schema_version", "review_id", "source_id", "source_role", "pipeline_fingerprint", "parser_repairs", "source",
    "toolchain", "configuration", "markdown", "pages", "blocks", "tables", "figures",
    "equations", "symbols", "proposal", "quality"
  ],
  "properties": {
    "schema_version": {"enum": ["0.1", "0.2", "0.3"]},
    "review_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "pattern": "^SRC-[0-9]{2,}$"},
    "source_role": {"enum": ["manuscript", "appendix", "supplement"]},
    "pipeline_fingerprint": {"$ref": "#/$defs/sha256"},
    "detector_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "source_sha256"],
      "properties": {
        "version": {"const": "1"},
        "source_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "parser_repairs": {
      "type": "object", "additionalProperties": false,
      "required": [
        "xml_forbidden_control_count", "xml_forbidden_codepoints", "raw_xhtml_sha256",
        "parser_input_sha256", "action"
      ],
      "properties": {
        "xml_forbidden_control_count": {"type": "integer", "minimum": 0},
        "xml_forbidden_codepoints": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "pattern": "^U\\+[0-9A-F]{4,6}$"}
        },
        "raw_xhtml_sha256": {"$ref": "#/$defs/sha256"},
        "parser_input_sha256": {"$ref": "#/$defs/sha256"},
        "action": {"const": "removed_xml_forbidden_controls_from_parser_input"}
      }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["original_name", "package_path", "sha256", "page_count", "encrypted"],
      "properties": {
        "original_name": {"type": "string", "minLength": 1},
        "package_path": {"$ref": "#/$defs/safePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "page_count": {"type": "integer", "minimum": 1},
        "encrypted": {"type": "boolean"}
      }
    },
    "toolchain": {
      "type": "object", "additionalProperties": false,
      "required": ["primary", "renderer", "table_extractor", "ocr", "proposal"],
      "properties": {
        "primary": {"$ref": "#/$defs/tool"},
        "renderer": {"$ref": "#/$defs/tool"},
        "table_extractor": {"$ref": "#/$defs/toolOrNull"},
        "ocr": {"$ref": "#/$defs/toolOrNull"},
        "proposal": {"$ref": "#/$defs/toolOrNull"},
        "semantic_backends": {"type": "array", "items": {"$ref": "#/$defs/tool"}}
      }
    },
    "configuration": {
      "type": "object", "additionalProperties": false,
      "required": ["dpi", "ocr", "max_pages", "max_bytes", "markitdown_proposal", "network_services"],
      "properties": {
        "dpi": {"type": "integer", "minimum": 150, "maximum": 400},
        "ocr": {"enum": ["auto", "never", "always"]},
        "ocr_language": {"type": "string", "pattern": "^[A-Za-z0-9_+-]{1,64}$"},
        "max_pages": {"type": "integer", "minimum": 1},
        "max_bytes": {"type": "integer", "minimum": 1},
        "markitdown_proposal": {"type": "boolean"},
        "semantic_backend": {"enum": ["none", "auto", "docling"]},
        "allow_model_downloads": {"type": "boolean"},
        "docling_formulas": {"type": "boolean"},
        "docling_timeout": {"type": "integer", "minimum": 60, "maximum": 86400},
        "docling_device": {"enum": ["auto", "cpu", "mps", "cuda", "xpu"]},
        "mathpix": {"type": "boolean"},
        "mathpix_timeout": {"type": "integer", "minimum": 60, "maximum": 86400},
        "mathpix_poll_interval": {"type": "number", "minimum": 0.1, "maximum": 60},
        "external_upload_authorization": {"oneOf": [{"type": "null"}, {"const": "mathpix"}]},
        "mathpix_retention_accepted": {"type": "boolean"},
        "network_services": {"enum": ["forbidden", "mathpix_authorized"]}
      }
    },
    "markdown": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "normalization"],
      "properties": {
        "path": {"$ref": "#/$defs/safePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "normalization": {"const": "none"}
      }
    },
    "pages": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": [
          "page", "width_points", "height_points", "text_method", "text_path",
          "text_sha256", "native_text_path", "native_text_sha256", "ocr_text_path",
          "ocr_text_sha256", "render_path", "render_sha256", "character_count",
          "replacement_character_count", "private_use_character_count", "status", "warnings"
        ],
        "properties": {
          "page": {"type": "integer", "minimum": 1},
          "width_points": {"type": "number", "exclusiveMinimum": 0},
          "height_points": {"type": "number", "exclusiveMinimum": 0},
          "text_method": {"enum": ["pdf_text_layer", "ocr", "none"]},
          "text_path": {"$ref": "#/$defs/safePath"},
          "text_sha256": {"$ref": "#/$defs/sha256"},
          "native_text_path": {"$ref": "#/$defs/safePath"},
          "native_text_sha256": {"$ref": "#/$defs/sha256"},
          "ocr_text_path": {"oneOf": [{"$ref": "#/$defs/safePath"}, {"type": "null"}]},
          "ocr_text_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
          "render_path": {"$ref": "#/$defs/safePath"},
          "render_sha256": {"$ref": "#/$defs/sha256"},
          "character_count": {"type": "integer", "minimum": 0},
          "replacement_character_count": {"type": "integer", "minimum": 0},
          "private_use_character_count": {"type": "integer", "minimum": 0},
          "status": {"enum": ["extracted", "ocr_fallback", "bounded"]},
          "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "blocks": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "page", "bbox", "kind", "raw_text", "markdown_start", "markdown_end", "sha256", "confidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^SRC-[0-9]{2,}-PDF-B[0-9]{4,}$"},
          "page": {"type": "integer", "minimum": 1},
          "bbox": {"$ref": "#/$defs/bbox"},
          "kind": {"enum": ["heading", "paragraph", "caption_table", "caption_figure", "equation_candidate", "footnote", "header_footer", "ocr_text", "bounded_page"]},
          "raw_text": {"type": "string"},
          "markdown_start": {"type": "integer", "minimum": 0},
          "markdown_end": {"type": "integer", "minimum": 0},
          "sha256": {"$ref": "#/$defs/sha256"},
          "confidence": {"enum": ["high", "medium", "low"]}
        }
      }
    },
    "tables": {"type": "array", "items": {"$ref": "#/$defs/object"}},
    "figures": {"type": "array", "items": {"$ref": "#/$defs/object"}},
    "equations": {"type": "array", "items": {"$ref": "#/$defs/object"}},
    "proposal": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/proposal"}
      ]
    },
    "proposals": {"type": "array", "items": {"$ref": "#/$defs/genericProposal"}},
    "reconciliation": {"$ref": "#/$defs/reconciliation"},
    "symbols": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["symbol", "codepoints", "normalized", "occurrences", "definition_candidates", "warnings"],
        "properties": {
          "symbol": {"type": "string", "minLength": 1},
          "codepoints": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^U\\+[0-9A-F]{4,6}$"}},
          "normalized": {"type": "string", "minLength": 1},
          "occurrences": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/occurrence"}},
          "definition_candidates": {"type": "array", "items": {"$ref": "#/$defs/occurrence"}},
          "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "quality": {
      "type": "object", "additionalProperties": false,
      "required": [
        "status", "page_count_match", "all_pages_rendered", "all_pages_have_text_or_boundary",
        "object_crops_hashed", "anchor_spans_valid", "requires_visual_verification", "warnings"
      ],
      "properties": {
        "status": {"enum": ["ready_for_review", "bounded", "failed"]},
        "page_count_match": {"type": "boolean"},
        "all_pages_rendered": {"type": "boolean"},
        "all_pages_have_text_or_boundary": {"type": "boolean"},
        "object_crops_hashed": {"type": "boolean"},
        "anchor_spans_valid": {"type": "boolean"},
        "requires_visual_verification": {"const": true},
        "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  },
  "$defs": {
    "safePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*[\\\\:])(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*[\\x00-\\x1f\\x7f]).+$"
    },
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "bbox": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"type": "number", "minimum": 0}
    },
    "tool": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}}
    },
    "toolOrNull": {"oneOf": [{"$ref": "#/$defs/tool"}, {"type": "null"}]},
    "occurrence": {
      "type": "object", "additionalProperties": false,
      "required": ["page", "block_id", "bbox", "context"],
      "properties": {
        "page": {"type": "integer", "minimum": 1},
        "block_id": {"type": "string", "pattern": "^SRC-[0-9]{2,}-PDF-B[0-9]{4,}$"},
        "bbox": {"$ref": "#/$defs/bbox"},
        "context": {"type": "string"}
      }
    },
    "object": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "page", "bbox", "caption", "crop_path", "crop_sha256", "transcription", "status", "warnings"],
      "properties": {
        "id": {"type": "string", "pattern": "^SRC-[0-9]{2,}-PDF-(TBL|FIG|EQ)-[0-9]{3,}$"},
        "page": {"type": "integer", "minimum": 1},
        "bbox": {"$ref": "#/$defs/bbox"},
        "caption": {"type": ["string", "null"]},
        "crop_path": {"$ref": "#/$defs/safePath"},
        "crop_sha256": {"$ref": "#/$defs/sha256"},
        "transcription": {"type": ["object", "null"]},
        "status": {"enum": ["candidate_needs_visual_verification", "strategies_agree_needs_visual_verification", "conflict_needs_visual_verification", "bounded"]},
        "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "proposal": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "engine", "version", "authoritative", "warnings"],
      "properties": {
        "path": {"$ref": "#/$defs/safePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "engine": {"const": "markitdown"},
        "version": {"type": "string", "minLength": 1},
        "authoritative": {"const": false},
        "warnings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "proposalArtifact": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "media_type"],
      "properties": {
        "path": {"$ref": "#/$defs/safePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "media_type": {"type": "string", "minLength": 1}
      }
    },
    "modelRevision": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "revision"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "pattern": "^[A-Za-z0-9._/-]{4,160}$"}
      }
    },
    "proposalProcessing": {
      "type": "object", "additionalProperties": false,
      "required": [
        "manuscript_uploaded", "user_authorized", "credential_source",
        "retention_policy", "remote_deletion", "request_id"
      ],
      "properties": {
        "manuscript_uploaded": {"type": "boolean"},
        "user_authorized": {"type": "boolean"},
        "credential_source": {"enum": ["none", "environment"]},
        "retention_policy": {"type": ["string", "null"]},
        "remote_deletion": {"enum": ["not_applicable", "confirmed", "unconfirmed", "failed"]},
        "request_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9_-]{4,160}$"}
      }
    },
    "genericProposal": {
      "type": "object", "additionalProperties": false,
      "required": [
        "id", "engine", "version", "role", "mode", "authoritative",
        "input_sha256", "artifacts", "model_revisions", "processing", "warnings"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^PRP-[A-Z0-9-]+$"},
        "engine": {"enum": ["markitdown", "docling", "mathpix"]},
        "version": {"type": "string", "minLength": 1},
        "role": {"enum": ["semantic_structure", "scientific_ocr"]},
        "mode": {"enum": ["local", "remote"]},
        "authoritative": {"const": false},
        "input_sha256": {"$ref": "#/$defs/sha256"},
        "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/proposalArtifact"}},
        "model_revisions": {"type": "array", "items": {"$ref": "#/$defs/modelRevision"}},
        "processing": {"$ref": "#/$defs/proposalProcessing"},
        "warnings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "reconciliation": {
      "type": "object", "additionalProperties": false,
      "required": [
        "status", "policy", "canonical_path", "canonical_sha256",
        "packets_path", "packets_sha256", "unresolved", "warnings"
      ],
      "properties": {
        "status": {"const": "packets_ready"},
        "policy": {"const": "render_authority_native_glyph_preservation"},
        "canonical_path": {"$ref": "#/$defs/safePath"},
        "canonical_sha256": {"$ref": "#/$defs/sha256"},
        "packets_path": {"$ref": "#/$defs/safePath"},
        "packets_sha256": {"$ref": "#/$defs/sha256"},
        "unresolved": {
          "type": "object", "additionalProperties": false,
          "required": ["pages", "tables", "figures", "equations"],
          "properties": {
            "pages": {"type": "integer", "minimum": 0},
            "tables": {"type": "integer", "minimum": 0},
            "figures": {"type": "integer", "minimum": 0},
            "equations": {"type": "integer", "minimum": 0}
          }
        },
        "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
