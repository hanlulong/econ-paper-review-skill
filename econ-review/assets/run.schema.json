{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/run.schema.json",
  "title": "econ-review run state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "review_id", "status", "mode", "target", "paper_family",
    "designs", "identity_handling", "assessment_boundary", "capabilities", "comment_policy",
    "stage_status", "gates_loaded", "counts", "verification_passed"
  ],
  "properties": {
    "schema_version": {"enum": ["0.1", "0.2", "0.3", "0.4"]},
    "review_id": {"type": "string", "minLength": 1},
    "paper_title": {"type": "string", "minLength": 1, "maxLength": 240},
    "assessment_date": {"type": "string", "format": "date"},
    "prior_round": {"$ref": "#/$defs/prior_round"},
    "status": {"enum": ["draft", "awaiting_checkpoint", "blocked", "verification_failed", "complete"]},
    "mode": {"enum": ["quick", "full"]},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["venue", "tier"],
      "properties": {
        "venue": {"type": ["string", "null"]},
        "tier": {"enum": ["top-general", "leading-field", "standard-field", "regional-specialized", "unspecified"]}
      }
    },
    "paper_family": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,79}$",
      "description": "Coarse descriptive routing metadata only. Source-derived extensions are allowed and never activate or suppress an audit burden."
    },
    "designs": {"type": "array", "items": {"type": "string"}},
    "requested_addons": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["journal_fit"]},
      "description": "Author-facing optional analyses explicitly requested for this run. Current full reviews record an empty array when none were requested."
    },
    "identity_handling": {"enum": ["identity_minimized", "blinded", "not_applied"]},
    "assessment_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources", "figures", "equations", "appendix", "notes"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "status", "notes"],
            "properties": {
              "source_id": {"type": ["string", "null"], "pattern": "^SRC-[0-9]{2,}$"},
              "path": {"type": "string", "minLength": 1},
              "status": {"enum": ["fully_read", "partially_read", "unreadable", "not_opened"]},
              "notes": {"type": "string"},
              "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
            }
          }
        },
        "figures": {"enum": ["visually_inspected", "captions_only", "partial", "not_present", "not_assessed"]},
        "equations": {"enum": ["source_preserved", "render_verified", "partial", "not_present", "not_assessed"]},
        "appendix": {"enum": ["fully_read", "partially_read", "not_available", "not_assessed"]},
        "notes": {"type": "string"}
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["live_literature_search", "replication_code"],
      "properties": {
        "live_literature_search": {"type": "boolean"},
        "replication_code": {
          "enum": ["not_supplied", "not_permitted", "static_only", "executed"],
          "description": "Observed replication-material boundary: not_supplied means no code was supplied; not_permitted means code was supplied but review was not authorized; static_only means supplied code was inspected without execution; executed means at least one authorized execution was performed."
        }
      }
    },
    "comment_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_target", "maximum", "exhaustive"],
      "properties": {
        "minimum_target": {"type": "integer", "minimum": 0},
        "maximum": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Legacy aggregate comment cap. New full reviews set this to null and use the two channel capacities below."
        },
        "substance_maximum": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Author-facing Detailed Comments capacity. This is not a discovery stopping rule or target."
        },
        "writing_maximum": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Author-facing Detailed Editing Comments capacity. This is not a discovery stopping rule or target."
        },
        "exhaustive": {"type": "boolean"}
      }
    },
    "stage_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intake", "reconstruction", "frontier", "audit", "counterargument", "synthesis", "verification", "delivery"],
      "properties": {
        "intake": {"$ref": "#/$defs/stage"},
        "reconstruction": {"$ref": "#/$defs/stage"},
        "frontier": {"$ref": "#/$defs/stage"},
        "audit": {"$ref": "#/$defs/stage"},
        "counterargument": {"$ref": "#/$defs/stage"},
        "synthesis": {"$ref": "#/$defs/stage"},
        "verification": {"$ref": "#/$defs/stage"},
        "delivery": {"$ref": "#/$defs/stage"}
      }
    },
    "gates_loaded": {"type": "array", "items": {"type": "string"}},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "major", "minor", "info", "essential"],
      "properties": {
        "critical": {"type": "integer", "minimum": 0},
        "major": {"type": "integer", "minimum": 0},
        "minor": {"type": "integer", "minimum": 0},
        "info": {"type": "integer", "minimum": 0},
        "essential": {"type": "integer", "minimum": 0}
      }
    },
    "verification_passed": {"type": "boolean"},
    "activated_burdens": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/burden"}
    },
    "telemetry": {
      "type": "object",
      "description": "Observed execution metadata for completed v0.2+ reviews. Do not estimate unavailable timing or token counts.",
      "additionalProperties": false,
      "required": ["passes", "agents_spawned", "wall_clock_seconds", "input_tokens", "output_tokens"],
      "properties": {
        "passes": {
          "type": "array",
          "description": "Human-readable names of review passes actually completed.",
          "items": {"type": "string", "minLength": 1}
        },
        "agents_spawned": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of subagents actually started during this review run."
        },
        "wall_clock_seconds": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Observed elapsed seconds, or null when the runtime does not expose a trustworthy value."
        },
        "input_tokens": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Observed input-token count, or null when unavailable."
        },
        "output_tokens": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Observed output-token count, or null when unavailable."
        }
      }
    }
  },
  "$defs": {
    "package_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))\\S(?:[^\\r\\n]*\\S)?$"
    },
    "prior_snapshot_path": {
      "allOf": [
        {"$ref": "#/$defs/package_path"},
        {"pattern": "^evidence/prior-round/[A-Za-z0-9][A-Za-z0-9._-]*\\.json$"}
      ]
    },
    "prior_round": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_findings_path", "review_actions_path", "revision_tasks_path",
        "agent_response_path"
      ],
      "properties": {
        "prior_findings_path": {"$ref": "#/$defs/prior_snapshot_path"},
        "review_actions_path": {"$ref": "#/$defs/prior_snapshot_path"},
        "revision_tasks_path": {"$ref": "#/$defs/prior_snapshot_path"},
        "agent_response_path": {
          "oneOf": [
            {"$ref": "#/$defs/prior_snapshot_path"},
            {"type": "null"}
          ]
        }
      },
      "description": "Activates next-round adjudication from immutable prior-round snapshots stored inside this review package."
    },
    "stage": {"enum": ["pending", "in_progress", "passed", "bounded", "failed", "not_applicable"]},
    "burden": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "object_type", "status", "activation_basis", "triggers", "nonactivation_reason"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,79}$"},
        "parent_id": {
          "type": ["string", "null"],
          "enum": [
            "logical_validity",
            "technical_validity",
            "methodological_validity",
            "measurement_validity",
            "identification_validity",
            "uncertainty_and_inference",
            "formal_validity",
            "computational_validity",
            "validation_and_fit",
            "counterfactual_validity",
            "scope_and_transport",
            "source_support",
            "reproducibility",
            "research_integrity_and_governance",
            "communication_integrity",
            "exhibit_integrity",
            null
          ],
          "description": "Stable conceptual parent used for cross-paper coverage. Current strict v0.4 rows require a non-null value; null is retained only for legacy-package compatibility."
        },
        "object_type": {"enum": ["claim", "design", "measurement", "inference", "theory", "computation", "literature", "writing", "exhibit", "reproducibility", "research_integrity", "other"]},
        "status": {"enum": ["active", "not_applicable"]},
        "activation_basis": {"enum": ["observed", "missing_required", "mixed", "not_applicable"]},
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref", "rationale"],
            "properties": {
              "kind": {"enum": ["anchor", "claim", "required_omission"]},
              "ref": {"type": "string", "minLength": 1},
              "rationale": {"type": "string", "minLength": 1}
            }
          }
        },
        "nonactivation_reason": {"type": ["string", "null"]}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "active"}}, "required": ["status"]},
          "then": {"properties": {"triggers": {"minItems": 1}, "nonactivation_reason": {"type": "null"}}}
        },
        {
          "if": {"properties": {"status": {"const": "not_applicable"}}, "required": ["status"]},
          "then": {"properties": {"triggers": {"maxItems": 0}, "nonactivation_reason": {"type": "string", "minLength": 1}}}
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"schema_version": {"enum": ["0.1", "0.2", "0.3"]}},
        "required": ["schema_version"]
      },
      "then": {"not": {"required": ["prior_round"]}}
    },
    {
      "if": {"properties": {"schema_version": {"const": "0.4"}}, "required": ["schema_version"]},
      "then": {"required": ["activated_burdens"]}
    },
    {
      "if": {
        "properties": {
          "schema_version": {"const": "0.4"},
          "mode": {"const": "full"}
        },
        "required": ["schema_version", "mode"]
      },
      "then": {
        "properties": {
          "comment_policy": {
            "properties": {"maximum": {"type": "null"}}
          }
        }
      }
    }
  ]
}
