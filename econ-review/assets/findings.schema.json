{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/econ-review/findings.schema.json",
  "title": "econ-review findings ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "findings"],
  "properties": {
    "schema_version": {"enum": ["0.1", "0.2", "0.3", "0.4"]},
    "review_id": {"type": "string", "minLength": 1},
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"schema_version": {"const": "0.3"}},
        "required": ["schema_version"]
      },
      "then": {
        "properties": {
          "findings": {
            "items": {
              "required": ["title", "decision_role", "repairability"]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"schema_version": {"const": "0.4"}},
        "required": ["schema_version"]
      },
      "then": {
        "properties": {
          "findings": {
            "items": {
              "required": [
                "title", "decision_role", "repairability", "paper_position",
                "evidence_boundary", "minimum_repair", "display_evidence_id",
                "related_evidence_ids", "related_locations"
              ],
              "properties": {
                "evidence": {
                  "items": {"required": ["id", "representation"]}
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "section": {"type": ["string", "null"]},
        "page": {"type": ["integer", "null"], "minimum": 1},
        "paragraph": {"type": ["string", "null"]},
        "lines": {"type": ["string", "null"]},
        "exhibit": {"type": ["string", "null"]},
        "equation": {"type": ["string", "null"]},
        "file": {"type": ["string", "null"]}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source", "locator", "content", "scope_checked"],
      "properties": {
        "id": {"type": "string", "pattern": "^EVD-[A-Z0-9_-]+$"},
        "type": {
          "enum": ["quote", "equation", "table_cell", "figure", "code", "literature", "absence_scope", "computation"]
        },
        "representation": {
          "enum": ["verbatim", "normalized_transcription", "composite_comparison", "reviewer_observation", "checked_absence", "computed_result"]
        },
        "anchor_id": {"type": ["string", "null"], "pattern": "^ANC-[0-9]{2,}$"},
        "anchor_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^ANC-[0-9]{2,}$"}
        },
        "computation_id": {"type": ["string", "null"], "pattern": "^CMP-[0-9]{2,}$"},
        "source_record_id": {"type": ["string", "null"], "pattern": "^EXT-[0-9]{2,}$"},
        "support_record_id": {"type": ["string", "null"], "pattern": "^EXT-[0-9]{2,}-SUP-[0-9]{2,}$"},
        "source": {"type": "string", "minLength": 1},
        "locator": {"$ref": "#/$defs/locator"},
        "content": {"type": ["string", "null"]},
        "scope_checked": {"type": ["string", "null"]}
      },
      "allOf": [
        {
          "if": {"properties": {"representation": {"const": "composite_comparison"}}, "required": ["representation"]},
          "then": {
            "required": ["anchor_ids"],
            "properties": {
              "anchor_ids": {"minItems": 2},
              "anchor_id": {"type": "null"},
              "content": {
                "type": "string",
                "pattern": "^\\[Reviewer comparison\\]"
              }
            }
          }
        }
      ]
    },
    "patch": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["before", "after"],
      "properties": {
        "before": {"type": "string"},
        "after": {"type": "string"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "importance_rank", "dimension", "critique_basis", "data_limitation", "claim_ids", "reader_effect", "severity", "essential", "status", "support_state",
        "issue", "why_it_matters", "evidence", "confidence", "counterargument",
        "fix", "verification"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_-]*-[0-9]{2,}$"},
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Consequence-centered user-facing title. Required by the v0.3 validator."
        },
        "decision_role": {
          "enum": ["potentially_dispositive", "posture_material", "revision_value", "polish"],
          "description": "Editorial relevance, separate from technical severity. Required by the v0.3 validator."
        },
        "repairability": {
          "enum": [
            "within_current_design", "claim_narrowing", "additional_analysis", "new_evidence",
            "redesign", "unclear", "no_clear_fix"
          ],
          "description": "Smallest credible repair class. Required by the v0.3 validator."
        },
        "report_channel": {
          "enum": ["substance", "writing"],
          "description": "Report routing. Substance findings appear in report.md. Writing findings include mechanics, language consistency, exhibit presentation, and optional style. Misleading load-bearing expression and source-support problems remain substance. Default substance."
        },
        "paper_position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source_id", "anchor_id", "ordinal"],
          "properties": {
            "source_id": {"type": "string", "pattern": "^SRC-[0-9]{2,}$"},
            "anchor_id": {"type": "string", "pattern": "^ANC-[0-9]{2,}$"},
            "ordinal": {"type": "integer", "minimum": 0}
          }
        },
        "evidence_boundary": {
          "type": "string",
          "minLength": 1,
          "description": "Concise statement of what the cited evidence does and does not establish."
        },
        "minimum_repair": {
          "type": "string",
          "minLength": 1,
          "description": "Smallest repair that would resolve or materially bound the concern."
        },
        "display_evidence_id": {"type": "string", "pattern": "^EVD-[A-Z0-9_-]+$"},
        "related_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^EVD-[A-Z0-9_-]+$"}
        },
        "related_locations": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "importance_rank": {"type": "integer", "minimum": 1},
        "dimension": {"type": "string", "minLength": 1},
        "critique_basis": {
          "enum": [
            "formal_or_computational_error", "identification_or_inference", "avoidable_data_handling",
            "claim_exceeds_evidence", "internal_inconsistency", "reader_clarity",
            "reporting_or_reproducibility", "contribution_or_positioning", "other"
          ]
        },
        "data_limitation": {
          "enum": [
            "not_data_related", "avoidable_handling", "inherent_but_claim_exceeds",
            "inherent_and_properly_bounded", "unclear"
          ]
        },
        "claim_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^CLM-[0-9]{2,}$"}},
        "reader_effect": {"type": "string", "minLength": 1},
        "severity": {"enum": ["critical", "major", "minor", "info"]},
        "essential": {"type": "boolean"},
        "status": {"enum": ["open", "challenged", "dismissed", "resolved"]},
        "support_state": {
          "enum": ["supported", "partially_supported", "in_conflict", "inconclusive_from_text", "not_assessed"]
        },
        "issue": {"type": "string", "minLength": 1},
        "why_it_matters": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "would_change_my_mind"],
          "properties": {
            "level": {"enum": ["high", "medium", "low"]},
            "would_change_my_mind": {"type": "string", "minLength": 1}
          }
        },
        "counterargument": {
          "type": "object",
          "additionalProperties": false,
          "required": ["author_reply", "search_scope", "result", "notes"],
          "properties": {
            "author_reply": {"type": "string", "minLength": 1},
            "search_scope": {"type": "string", "minLength": 1},
            "result": {"enum": ["survived", "weakened", "refuted", "not_run", "not_applicable"]},
            "notes": {"type": "string"}
          }
        },
        "fix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["what", "how", "resolved_when", "strategy", "patch", "effort", "publishability", "dependencies", "requires_new_data", "current_design_can_support_primary_fix", "claim_narrowing_alternative"],
          "properties": {
            "what": {"type": "string", "minLength": 1},
            "how": {"type": "string", "minLength": 1},
            "resolved_when": {"type": "string", "minLength": 1},
            "strategy": {
              "enum": [
                "correct_error", "add_analysis", "improve_validation", "clarify_or_disclose",
                "narrow_claim", "reorganize_or_rewrite", "provide_reproducibility", "redesign", "other"
              ]
            },
            "patch": {"$ref": "#/$defs/patch"},
            "effort": {"enum": ["hours", "days", "weeks", "new-data", "not-estimable"]},
            "publishability": {"type": "string", "minLength": 1},
            "dependencies": {"type": "array", "items": {"type": "string"}},
            "requires_new_data": {"type": "boolean"},
            "current_design_can_support_primary_fix": {"type": "boolean"},
            "claim_narrowing_alternative": {"type": ["string", "null"]}
          }
        },
        "verification": {"enum": ["pending", "passed", "failed", "bounded"]}
      }
    }
  }
}
